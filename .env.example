# ==============================================================================
# WHALEHUB SERVER CONFIGURATION
# ==============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=whalehub

# ==============================================================================
# STELLAR & SOROBAN CONFIGURATION
# ==============================================================================

# Network Configuration
STELLAR_NETWORK=PUBLIC
STELLAR_HORIZON_URL=https://horizon.stellar.org
SOROBAN_RPC_URL=https://soroban-rpc.stellar.org

# Admin Keys (DO NOT COMMIT REAL SECRETS!)
ADMIN_SECRET_KEY=S...
SOROBAN_ISSUER_SECRET_KEY=S...

# ==============================================================================
# SMART CONTRACT ADDRESSES
# ==============================================================================

# Main Staking Contract
STAKING_CONTRACT_ID=C...

# AQUA Token (SAC)
AQUA_TOKEN_ID=C...
AQUA_ISSUER=G...

# BLUB Token (SAC)
BLUB_TOKEN_ID=C...

# Aquarius Integration
AQUARIUS_ROUTER_CONTRACT_ID=C...

# ==============================================================================
# ICE TOKEN ADDRESSES (SAC Wrapped)
# ==============================================================================

# ICE Token (Base)
ICE_TOKEN_ID=C...

# governICE Token
GOVERN_ICE_TOKEN_ID=C...

# upvoteICE Token (used for voting)
UPVOTE_ICE_TOKEN_ID=C...

# downvoteICE Token
DOWNVOTE_ICE_TOKEN_ID=C...

# ==============================================================================
# CRON JOB CONFIGURATION
# ==============================================================================

# ICE Locking Cron
# Runs daily at 2:00 AM UTC by default
# Format: minute hour day month dayOfWeek
# ICE_LOCKING_CRON_SCHEDULE=0 2 * * *

# Vault Compound Cron
# Runs 4x daily at 0, 6, 12, 18 UTC by default
# VAULT_COMPOUND_CRON_SCHEDULE=0 0,6,12,18 * * *

# Voting Cron
# Runs weekly on Sunday at 3:00 AM UTC by default
# Change this to customize voting frequency:
# Daily: 0 3 * * *
# Every 3 days: 0 3 */3 * *
# Weekly: 0 3 * * 0
# Bi-weekly: 0 3 */14 * *
VOTING_CRON_SCHEDULE=0 3 * * 0

# ==============================================================================
# VOTING CONFIGURATION
# ==============================================================================

# Percentage of voting power to allocate to AQUA-BLUB pool (0-100)
AQUA_BLUB_VOTING_SHARE=60

# Reward tokens per second (7 decimal precision)
# Example: 600 AQUA/sec = 600_0000000
REWARD_TPS=6000000000

# ==============================================================================
# VAULT CONFIGURATION
# ==============================================================================

# Treasury address for vault fees (30% of claimed rewards)
VAULT_TREASURY_ADDRESS=G...

# Vault fee in basis points (3000 = 30%)
VAULT_FEE_BPS=3000
